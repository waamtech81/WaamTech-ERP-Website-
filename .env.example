# Public marketing site URL (verification emails)
NEXT_PUBLIC_SITE_URL=https://waamtech.com

# Live WAAMTO ERP application — all logins redirect here
NEXT_PUBLIC_APP_URL=https://app.waamto.com
NEXT_PUBLIC_TRIAL_DAYS=14

# License server — trial registration, package activation, license email (backend)
# Local: http://localhost:4001/api
LICENSE_API_URL=https://license.waamto.com/api
LICENSE_API_KEY=
NEXT_PUBLIC_LICENSE_PORTAL_URL=https://license.waamto.com

# Optional ERP Core API (locale sync only — tenant provisioning is owned by License Engine)
# Also used by /api/locale to sync language/currency with SaaS Core
# (GET /settings/public/localization, GET/PUT /auth/locale)
WAAMTECH_API_URL=http://localhost:5001/api

# Global currency: USD-based exchange-rate service (all optional).
# Defaults to https://open.er-api.com/v6/latest/USD (no key) with static fallback.
# Rates refresh daily (86400s). Master / billing currency is always USD.
# EXCHANGE_RATES_API_URL=https://open.er-api.com/v6/latest/USD
# EXCHANGE_RATES_API_KEY=
# EXCHANGE_RATES_TTL=86400

# Legacy (unused when License Engine owns OTP): encrypts pending signup passwords
# VERIFICATION_SECRET=change-me-to-a-long-random-string

# Email delivery via Resend — optional on website; License Engine sends OTP/welcome emails
RESEND_API_KEY=
EMAIL_FROM="WAAMTO <noreply@yourdomain.com>"

# Dev only: allow console verification links when Resend is unset
# ALLOW_CONSOLE_EMAIL=1
