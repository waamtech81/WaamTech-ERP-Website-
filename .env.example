# Public marketing site URL (verification / password-reset return links)
# Production (cPanel): https://waamto.com
NEXT_PUBLIC_SITE_URL=https://waamto.com

# Live WAAMTO ERP application — deep links / open ERP from portal
NEXT_PUBLIC_APP_URL=https://app.waamto.com
NEXT_PUBLIC_TRIAL_DAYS=14

# License Engine — REQUIRED (cPanel production)
# NEXT_PUBLIC_LICENSE_ENGINE_URL=https://api.license.waamtech.com
# NEXT_PUBLIC_LICENSE_PORTAL=https://license.waamtech.com
#
# Owns: identity login, Login OTP, JWT/refresh, password reset emails, licenses,
# AND public commercial catalog + customer billing (Phase 4 SSOT)
# AND Platform Super Admin / staff auth (POST /api/v1/auth/login) — same users
# table as License Engine Admin Portal (one identity, one password).
# Website password login uses /v1/identity/login only (Engine tryLogin for Super Admin).
# Do not probe /v1/auth/login for every customer email.
# Local: http://localhost:4001/api
# Production engine: https://api.license.waamtech.com  (code appends /api)
#
# Public catalog (no auth):
#   GET /v1/public/catalog/products|plans|pricing|industries|business-categories|business-profiles
#   GET /v1/public/catalog/plans/comparison?product=
#   GET /v1/public/catalog/plans/:id|/:id/limits|/:id/features
#   GET /v1/public/catalog/feature-groups|modules
# Public billing (customer identity JWT):
#   GET /v1/public/billing/subscriptions|invoices|payments|renewals|history
#   GET /v1/public/billing/invoices/:id|/document|/pdf
#   GET /v1/public/billing/gateways|dashboard|company
#   POST /v1/public/billing/subscriptions/:id/renew|plan-changes|trial-convert|checkout
# Customer support + notifications (identity JWT):
#   /v1/identity/support/tickets|notifications
# Identity profile:
#   PATCH /v1/identity/profile | POST /v1/identity/profile/photo | POST /v1/identity/change-password
#
# Password reset emails must link to:
#   {NEXT_PUBLIC_SITE_URL}/reset-password?token=...
# Configure that return URL on the License Engine (Website does not send reset mail).
NEXT_PUBLIC_LICENSE_ENGINE_URL=https://api.license.waamtech.com
NEXT_PUBLIC_LICENSE_PORTAL=https://license.waamtech.com
LICENSE_API_URL=https://api.license.waamtech.com/api
LICENSE_API_KEY=
# Admin Portal origin for Platform Super Admin SSO after Website login.
# Production: https://license.waamtech.com
# Local: use http://localhost:<portal-port> AND open the Website via http://localhost
# as well. Opening the site via a LAN IP / tunnel while this is localhost triggers
# Chrome's "Allow other apps and services on this device" (loopback-network) prompt.
NEXT_PUBLIC_LICENSE_PORTAL_URL=https://license.waamtech.com

# Auth architecture (local + production — same flow):
#   Browser → POST /api/auth/login (same origin only)
#   Next.js server → Control Center LICENSE_API_URL (/v1/identity/login)
#   Password step uses identity login only (Engine resolves Platform Super Admin
#   via tryLogin). Do NOT probe /v1/auth/login for every customer email — that
#   recorded IP failures and could lock accounts / show staff OTP incorrectly.
#   Browser never calls localhost Control Center APIs directly (avoids Apps-on-device).
# Standard customer login: email + password. OTP only when email is unverified.
# No OAuth / OIDC / WebAuthn / device-authorization consent in this flow.

# Commercial catalog cache (seconds / ms)
# COMMERCIAL_CATALOG_REVALIDATE=60
# NEXT_PUBLIC_CATALOG_STALE_MS=60000
# NEXT_PUBLIC_CATALOG_MAX_AGE_MS=300000

# Optional ERP Core API (locale sync + optional portal stats widgets)
# Local: http://localhost:5001/api
# Production: https://apierp.waamto.com/api
WAAMTECH_API_URL=https://apierp.waamto.com/api

# Email delivery via Resend — optional on website (newsletter only).
# System emails (OTP, reset, welcome, invoices) are owned by License Engine.
RESEND_API_KEY=
EMAIL_FROM="WAAMTO <noreply@waamto.com>"

NEWSLETTER_INBOX=newsletters@waamto.com

# Google reCAPTCHA v2 (contact form)
# Create keys at https://www.google.com/recaptcha/admin (v2 Checkbox)
# Add domain: waamto.com (and localhost for local testing)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Rate limiting store (optional — defaults to in-memory for local/dev)
# For production multi-instance / serverless, set Upstash Redis REST credentials:
# RATE_LIMIT_STORE=upstash
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Site maintenance mode — redirects all public pages to /maintenance
# SITE_MAINTENANCE=1
# NEXT_PUBLIC_SITE_MAINTENANCE=1

# Native app store links (footer badges) — add when listings are live
# NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id
